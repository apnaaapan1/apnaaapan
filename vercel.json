{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    {
      "source": "/api/videos",
      "destination": "/api/media-router?route=videos"
    },
    {
      "source": "/api/cloudinary-video-signature",
      "destination": "/api/media-router?route=cloudinary-video-signature"
    },
    {
      "source": "/api/graphics",
      "destination": "/api/media-router?route=graphics"
    },
    {
      "source": "/api/cloudinary-graphic-signature",
      "destination": "/api/media-router?route=cloudinary-graphic-signature"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

